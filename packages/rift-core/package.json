{
  "name": "@rift-vs/rift",
  "version": "0.12.1",
  "description": "Official Node.js / TypeScript SDK for Rift - a high-performance, Mountebank-compatible HTTP/HTTPS mock server",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "minEngineVersion": "0.12.0",
  "bin": {
    "rift-fetch": "bin/rift-fetch.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./compat": {
      "types": "./dist/compat/index.d.ts",
      "import": "./dist/compat/index.js"
    },
    "./testkit/vitest": {
      "types": "./dist/testkit/vitest.d.ts",
      "import": "./dist/testkit/vitest.js"
    },
    "./testkit/jest": {
      "types": "./dist/testkit/jest.d.ts",
      "import": "./dist/testkit/jest.js"
    },
    "./intercept-undici": {
      "types": "./dist/intercept-undici.d.ts",
      "import": "./dist/intercept-undici.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js",
    "test:unit": "npm test -- --testPathPattern=test/unit",
    "test:integration": "npm test -- --testPathPattern=test/integration",
    "test:embedded": "node --experimental-vm-modules ../../node_modules/jest/bin/jest.js --config jest.embedded.config.js",
    "test:leaks": "npm test -- --detectOpenHandles",
    "prepublishOnly": "npm run build",
    "lint": "eslint src test examples scripts --ext .ts,.mjs",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json --noEmit",
    "docs:check": "node scripts/check-docs-embeds.mjs"
  },
  "dependencies": {},
  "peerDependencies": {
    "@rift-vs/rift-embedded": "*",
    "undici": ">=6",
    "vitest": ">=1"
  },
  "peerDependenciesMeta": {
    "@rift-vs/rift-embedded": {
      "optional": true
    },
    "undici": {
      "optional": true
    },
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "bin",
    "binaries/.gitkeep"
  ],
  "keywords": [
    "mountebank",
    "mock",
    "stub",
    "test",
    "double",
    "chaos",
    "engineering",
    "rift",
    "service-virtualization",
    "api-mocking"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EtaCassiopeia/rift-node.git",
    "directory": "packages/rift-core"
  },
  "bugs": {
    "url": "https://github.com/EtaCassiopeia/rift-node/issues"
  },
  "homepage": "https://github.com/EtaCassiopeia/rift-node#readme",
  "license": "MIT",
  "author": "Rift Contributors",
  "publishConfig": {
    "access": "public"
  }
}
